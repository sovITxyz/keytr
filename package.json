{
  "name": "@sovit.xyz/keytr",
  "version": "0.1.2",
  "description": "Passkey login for Nostr. Encrypt your nsec with a WebAuthn passkey, publish to relays, decrypt on any device. Implements NIP-K1.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./crypto": {
      "types": "./dist/crypto/index.d.ts",
      "import": "./dist/crypto/index.js"
    },
    "./webauthn": {
      "types": "./dist/webauthn/index.d.ts",
      "import": "./dist/webauthn/index.js"
    },
    "./nostr": {
      "types": "./dist/nostr/index.d.ts",
      "import": "./dist/nostr/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "dev": "vite demo",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "nostr",
    "passkey",
    "webauthn",
    "fido2",
    "nsec",
    "encryption",
    "prf"
  ],
  "author": "sovITxyz",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sovITxyz/keytr.git"
  },
  "homepage": "https://github.com/sovITxyz/keytr",
  "license": "AGPL-3.0-or-later",
  "dependencies": {
    "@noble/ciphers": "^1.2.1",
    "@noble/hashes": "^1.7.1",
    "@scure/base": "^1.2.4",
    "nostr-tools": "^2.12.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vite": "^6.2.0",
    "vitest": "^3.0.0"
  }
}
